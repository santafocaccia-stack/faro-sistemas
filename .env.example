# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Postgres connection string
# Local: postgresql://user:pass@localhost:5432/faro
# Supabase: ver dashboard Supabase → Project Settings → Database → Connection string
DATABASE_URL=

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
# Settings → API en el dashboard de Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo server-side. NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────
# MERCADO PAGO (más adelante)
# ─────────────────────────────────────────
# MP_ACCESS_TOKEN=
# MP_PUBLIC_KEY=
# Secreto de firma del webhook (Tus integraciones → tu app → Webhooks → Clave secreta).
# OBLIGATORIO en producción: sin él, /api/mp-webhook rechaza todo (fail-closed).
# MP_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# AFIP — Tusfacturas (más adelante)
# ─────────────────────────────────────────
# TUSFACTURAS_API_KEY=
# TUSFACTURAS_API_TOKEN=
# TUSFACTURAS_USER_TOKEN=

# ─────────────────────────────────────────
# RESEND (email transaccional)
# ─────────────────────────────────────────
# RESEND_API_KEY=

# ─────────────────────────────────────────
# IA — análisis mensual de gastos/balance (Claude)
# ─────────────────────────────────────────
# Sin esto, el balance funciona igual pero el análisis cae a un resumen sin IA.
# ANTHROPIC_API_KEY=
# Opcional: modelo a usar (default: claude-sonnet-4-6)
# GASTOS_ANALISIS_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────
# PLATAFORMA — super-admin + cobro por transferencia
# ─────────────────────────────────────────
# Emails con acceso al panel /admin (separados por coma). Sin esto, nadie entra.
# SUPER_ADMIN_EMAILS=tomasemanueldesousa@gmail.com
# Datos de la cuenta donde el cliente transfiere la suscripción (se muestran en /planes):
# TRANSFER_TITULAR=
# TRANSFER_BANCO=
# TRANSFER_CBU=
# TRANSFER_ALIAS=
# TRANSFER_CUIT=

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cifrado at-rest de tokens OAuth de Mercado Pago (openssl rand -base64 32)
MP_TOKEN_ENC_KEY=
