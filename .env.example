# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Postgres connection string
# Local: postgresql://user:pass@localhost:5432/faro
# Supabase: ver dashboard Supabase → Project Settings → Database → Connection string
DATABASE_URL=

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
# Settings → API en el dashboard de Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo server-side. NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

