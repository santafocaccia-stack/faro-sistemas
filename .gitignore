# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/e2e/.auth/session.json
/e2e/report/
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server.log

# datos generados por scripts (catálogo OFF, etc.)
scripts/output/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# artefactos de generación / contexto (no forman parte del producto)
/gesto-*.txt
/canvas-fonts/
/generate_gesto.py

# cache local del hook de contexto (firma de estado, no versionar)
/.claude/hooks/.last-state
